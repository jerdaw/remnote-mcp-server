{
  "name": "remnote-mcp-server",
  "version": "0.13.0",
  "description": "MCP server bridge for RemNote knowledge base",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "remnote-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "tsx test/integration/run-integration.ts",
    "test:ui": "vitest --ui",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "quality": "./code-quality.sh",
    "precommit": "./code-quality.sh"
  },
  "keywords": [
    "mcp",
    "remnote",
    "model-context-protocol",
    "knowledge-base",
    "note-taking",
    "ai",
    "assistant",
    "websocket",
    "bridge"
  ],
  "author": "nightingale7 <nightingale7@gmail.com>",
  "license": "MIT",
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robert7/remnote-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/robert7/remnote-mcp-server/issues"
  },
  "homepage": "https://github.com/robert7/remnote-mcp-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "express": "^5.2.0",
    "pino": "^10.3.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
